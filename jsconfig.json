{
	"compilerOptions": {
		"alwaysStrict": true,
		"checkJs": true,
		"declaration": true,
		"declarationMap": true,
		"module": "node16",
		"noEmit": true,
		"noImplicitOverride": true,
		"noImplicitThis": true,
		"resolveJsonModule": true,
		"sourceMap": true,
		"strictBindCallApply": true,
		"strictFunctionTypes": true,
		"strictNullChecks": true,
		"strictPropertyInitialization": true,
		"target": "es2020",
		"types": [],
		"useUnknownInCatchVariables": true,
		"verbatimModuleSyntax": true
	},
	"exclude": [
		"coverage",
		"node_modules",
		"**/*.spec.js",
		"test/**/*",
		"**/test/**/*"
	],
	"include": [
		"**/*.js"
	]
}