{
  "name": "@dotcom-reliability-kit/serialize-request",
  "version": "4.2.0",
  "type": "module",
  "description": "A utility function to serialize a request object in a way that's friendly to loggers, view engines, and converting to JSON",
  "repository": {
    "type": "git",
    "url": "https://github.com/Financial-Times/dotcom-reliability-kit.git",
    "directory": "packages/serialize-request"
  },
  "homepage": "https://github.com/Financial-Times/dotcom-reliability-kit/tree/main/packages/serialize-request#readme",
  "bugs": "https://github.com/Financial-Times/dotcom-reliability-kit/issues?q=label:\"package: serialize-request\"",
  "license": "MIT",
  "scripts": {
    "test": "npm run test:unit && npm run test:end-to-end",
    "test:unit": "node --test --experimental-test-module-mocks --experimental-test-coverage --test-coverage-exclude='**/*.spec.ts' --test-coverage-branches=100 --test-coverage-functions=100 --test-coverage-lines=100 'test/unit/**/*.spec.ts'",
    "test:end-to-end": "node --test 'test/end-to-end/**/*.spec.ts'"
  },
  "engines": {
    "node": "^22.12 || ^24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "**/*.ts",
    "dist",
    "!*.tsbuildinfo",
    "!test"
  ],
  "devDependencies": {
    "@types/express": "^5.0.6"
  }
}
